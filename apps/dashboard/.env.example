# ─── KubeHero dashboard · environment ──────────────────────────────────────
#
# Copy to .env.local for local dev. Set on Vercel for production.

# Control-plane URL (Connect-RPC). When unset, the dashboard renders demo
# data. The DataSourceBadge in every page header shows live | demo.
CONTROL_PLANE_URL=http://127.0.0.1:18080

# Bearer token for authenticated control-plane calls. Required when the
# cp runs with KUBEHERO_REQUIRE_AUTH=true. For local dev, leave empty.
# CONTROL_PLANE_TOKEN=

# Cluster id this dashboard's session is scoped to. Optional today;
# becomes mandatory once multi-tenant filtering ships.
# CLUSTER_ID=
